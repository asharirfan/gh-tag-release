{
  "name": "gh-tag-release",
  "version": "0.0.2",
  "description": "Turn git tags into GitHub releases instantly.",
  "type": "module",
  "bin": {
    "gh-tag-release": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "link": "pnpm link --global",
    "prepublishOnly": "pnpm test && pnpm build",
    "publish:npm": "pnpm run prepublishOnly && pnpm publish",
    "publish:npm:dry-run": "pnpm run prepublishOnly && pnpm publish --dry-run",
    "release:major": "node scripts/release.mjs major",
    "release:minor": "node scripts/release.mjs minor",
    "release:patch": "node scripts/release.mjs patch",
    "test": "vitest run",
    "test:watch": "vitest",
    "unlink": "pnpm unlink --global"
  },
  "keywords": [
    "cli",
    "github",
    "release",
    "git",
    "tags"
  ],
  "author": "Ashar Irfan",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asharirfan/gh-tag-release.git"
  },
  "homepage": "https://github.com/asharirfan/gh-tag-release#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.6.5"
}
